{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check_memory_size.py\"",
            "timeout": 10,
            "statusMessage": "Checking memory size"
          }
        ]
      }
    ]
  }
}
